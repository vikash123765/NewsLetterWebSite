﻿@using Microsoft.AspNetCore.Mvc.Rendering
@model IEnumerable<NewsLetterBanan.Data.Article>

@{
    bool isLoggedIn = ViewBag.IsLoggedIn ?? false;
    var categories = ViewBag.Categories as List<NewsLetterBanan.Data.Category>;
}

<div class="container my-4">
    <h1 class="mb-4">Articles</h1>

    @if (ViewBag.Message != null)
    {
        <p>@ViewBag.Message</p>
    }
    else
    {
        @if (Model != null && Model.Any())
        {
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card">
                            <div class="card-body">
                                <p><strong>Headline:</strong> @item.Headline</p>
                                @if (item.User != null)
                                {
                                    <p><strong>By:</strong> @item.User.FirstName @item.User.LastName</p>
                                }
                                else
                                {
                                    <p><strong>By:</strong> Unknown Author</p>
                                }
                                <p><strong>Content Summary:</strong> @item.ContentSummary</p>
                                <p><strong>Content:</strong> @item.Content</p>
                                <p>
                                    <strong>Category:</strong>
                                    @if (item.Categories != null && item.Categories.Count == 1)
                                    {
                                        @item.Categories.First().Name
                                    }
                                    else if (item.Categories != null && item.Categories.Count > 1)
                                    {
                                        @string.Join(", ", item.Categories.Select(c => c.Name))
                                    }
                                    else
                                    {
                                        <span>No Category</span>
                                    }
                                </p>
                                <p>
                                    <strong>Category Description:</strong>
                                    @if (item.Categories != null && item.Categories.Count == 1)
                                    {
                                        @item.Categories.First().Description
                                    }
                                    else if (item.Categories != null && item.Categories.Count > 1)
                                    {
                                        @string.Join(", ", item.Categories.Select(c => c.Description))
                                    }
                                    else
                                    {
                                        <span>No Category Description</span>
                                    }
                                </p>
                                <p>
                                    <strong>Tags:</strong>
                                    @if (item.Tags != null && item.Tags.Count == 1)
                                    {
                                        @item.Tags.First().TagName
                                    }
                                    else if (item.Tags != null && item.Tags.Count > 1)
                                    {
                                        @string.Join(", ", item.Tags.Select(t => t.TagName))
                                    }
                                    else
                                    {
                                        <span>No Tags</span>
                                    }
                                </p>
                                <p>
                                    <strong>Tag Descriptions:</strong>
                                    @if (item.Tags != null && item.Tags.Count == 1)
                                    {
                                        @item.Tags.First().TagDescription
                                    }
                                    else if (item.Tags != null && item.Tags.Count > 1)
                                    {
                                        @string.Join(", ", item.Tags.Select(t => t.TagDescription))
                                    }
                                    else
                                    {
                                        <span>No Tag Descriptions</span>
                                    }
                                </p>
                                <p>
                                    <strong>Images:</strong>
                                    @if (item.Images != null && item.Images.Any())
                                    {
                                        <div class="mt-3">
                                            <ul class="list-unstyled">
                                                @foreach (var img in item.Images)
                                                {
                                                    <li class="mb-2">
                                                        <p><strong>Title:</strong> @img.Title</p>
                                                        <p><strong>Description:</strong> @img.ImgDescription</p>
                                                        <p><strong>Source URL:</strong> <a href="@img.ImgSourceURL" target="_blank">@img.ImgSourceURL</a></p>
                                                        <p><strong>Taken By:</strong> @img.TakenBy</p>
                                                        <p><strong>License:</strong> @img.License</p>
                                                        @if (!string.IsNullOrEmpty(img.ImgSourceURL))
                                                        {
                                                            <img src="@img.ImgSourceURL" class="img-fluid rounded" alt="@img.Title" />
                                                        }
                                                    </li>
                                                    <hr />
                                                }
                                            </ul>
                                        </div>
                                    }
                                </p>
                                <p><strong>Published Date:</strong> @item.DateStamp.ToString("MMMM dd, yyyy")</p>
                                <p>
                                    <strong>Editor's Choice:</strong>
                                    <span class="badge @(item.IsEditorsChoice ? "bg-success" : "bg-secondary")">
                                        @(item.IsEditorsChoice ? "Yes" : "No")
                                    </span>
                                </p>
                                <p><strong>Source URL:</strong> @item.SourceURL</p>
                                <p><strong>Archived:</strong> @(item.IsArchived ? "Yes" : "No")</p>
                                <!-- Display counts -->
                                <p><strong>Likes:</strong> <span id="likeCount-@item.Id">@(ViewBag.LikeCounts?.ContainsKey(item.Id) == true ? ViewBag.LikeCounts[item.Id] : 0)</span></p>
                                <button class="btn btn-outline-primary btn-sm" onclick="toggleLike(@item.Id)">👍 Like</button>
                                <p><strong>Comments:</strong> <span id="commentCount-@item.Id">@(ViewBag.CommentCounts?.ContainsKey(item.Id) == true ? ViewBag.CommentCounts[item.Id] : 0)</span></p>
                                <button class="btn btn-primary btn-sm" onclick="toggleCommentSection(@item.Id)">Show Comments</button>
                                <p><strong>Replies:</strong> <span id="replyCount-@item.Id">@(ViewBag.ReplyCounts?.ContainsKey(item.Id) == true ? ViewBag.ReplyCounts[item.Id] : 0)</span></p>
                                <p><strong>Views:</strong> @item.Views</p>

                                <!-- Add Comment Form -->
                                <div id="commentSection-@item.Id" class="comment-section mt-3" style="display: none;">
                                    <h5>Comments</h5>
                                    <div id="commentsContainer-@item.Id">
                                        <p>Loading comments...</p>
                                    </div>
                                    <div class="mt-3">
                                        <textarea id="commentContent-@item.Id" class="form-control" placeholder="Write a comment..."></textarea>
                                        <button class="btn btn-success btn-sm mt-2" onclick="addComment(@item.Id)">Post Comment</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p>No articles available.</p>
        }
    }
</div>
<<script>
     document.addEventListener("DOMContentLoaded", async function () {
         await fetchAllLikeCounts(); // Fetch like counts immediately
         await fetchAllCommentCounts(); // Fetch comment counts immediately
         await fetchAllReplies(); // Fetch replies and counts immediately
     });

     // Retrieve actual user ID from ViewData
     const userId = '@ViewData["UserId"]'.trim();


     //fetch like count for article
     function fetchLikeCount(articleId) {
         fetch(`/User/GetArticleLikes?articleId=${articleId}`)
             .then(response => response.json())
             .then(data => {
                 document.getElementById(`likeCount-${articleId}`).innerText = data.likes;
             });
     }
     // Toggle Like/Unlike
     function toggleLike(articleId) {
         fetch(`/User/ToggleArticleLike`, {
             method: "POST",
             headers: { "Content-Type": "application/json" },
             body: JSON.stringify({ ArticleId: articleId, UserId: userId })
         }).then(() => fetchLikeCount(articleId));
     }

     // fetch comment count for article
     function fetchAllCommentCounts() {
         fetch(`/User/GetAllCommentCounts`)
             .then(response => response.json())
             .then(allComments => {
                 allComments.forEach(commentData => {
                     let commentCountElement = document.getElementById(`commentCount-${commentData.articleId}`);
                     if (commentCountElement) {
                         commentCountElement.innerText = commentData.commentCount;
                     }
                 });
             });
     }
     // Toggle Comment Section
     function toggleCommentSection(articleId) {
         let section = document.getElementById("commentSection-" + articleId);
         if (section.style.display === "none") {
             section.style.display = "block";
             fetchComments(articleId);
         } else {
             section.style.display = "none";
         }
     }

     // Fetch Comments for an Article
     function fetchComments(articleId) {
         fetch(`/User/GetComments?articleId=${articleId}`)
             .then(response => response.json())
             .then(comments => {
                 let commentsContainer = document.getElementById(`commentsContainer-${articleId}`);
                 let commentCountElement = document.getElementById(`commentCount-${articleId}`);
                 commentsContainer.innerHTML = ""; // Clear old comments

                 if (comments.length === 0) {
                     commentsContainer.innerHTML = "<p>No comments yet.</p>";
                 } else {
                     commentCountElement.innerText = comments.length; // Update comment count
                     comments.forEach(comment => {
                         commentsContainer.innerHTML += `
                                           <div class="comment-box border p-2 mb-2">
                                               <p><strong>${comment.userName}</strong> - ${new Date(comment.dateStamp).toLocaleString()}</p>
                                               <p>${comment.content}</p>
                                                 <p>Likes: <span id="commentLikeCount-${comment.id}">0</span></p>
                                               <p>Replies: <span id="replyCount-${comment.id}">0</span></p>

                                               <button class="btn btn-secondary btn-sm" onclick="toggleReplies(${comment.id})">Show Replies</button>
                                                 <button class="btn btn-info btn-sm" onclick="toggleCommentLike(${comment.id})">Like Comment</button>
                                               <button class="btn btn-danger btn-sm" onclick="deleteComment(${comment.id}, ${articleId})">Delete</button>
                                               <button class="btn btn-warning btn-sm" onclick="editComment(${comment.id}, '${comment.content}', ${articleId})">Edit</button>

                                               <!-- Replies Section -->
                                               <div id="replySection-${comment.id}" class="reply-section mt-2" style="display: none;">
                                                   <div id="repliesContainer-${comment.id}">Loading replies...</div>

                                                   <!-- Add Reply Form -->
                                                   <div class="mt-2">
                                                       <textarea id="replyContent-${comment.id}" class="form-control" placeholder="Write a reply..."></textarea>
                                                       <button class="btn btn-success btn-sm mt-2" onclick="addReply(${comment.id})">Reply</button>
                                                   </div>
                                               </div>
                                           </div>
                                       `;
                     });
                     // Fetch and display like count for each comment
                     GetCommentLikeCounts(comment.id);
                     // Fetch replies after rendering comments
                     comments.forEach(comment => fetchReplies(comment.id));
                 }
             });
     }


     function fetchAllReplies() {
         fetch(`/User/GetAllReplies`)
             .then(response => response.json())
             .then(allReplies => {
                 allReplies.forEach(replyData => {
                     let repliesContainer = document.getElementById(`repliesContainer-${replyData.commentId}`);
                     let replyCountElement = document.getElementById(`replyCount-${replyData.commentId}`);

                     if (repliesContainer) {
                         repliesContainer.innerHTML = ""; // Clear old replies
                         if (replyData.replies.length === 0) {
                             repliesContainer.innerHTML = "<p>No replies yet.</p>";
                         } else {
                             replyCountElement.innerText = replyData.replies.length; // Update reply count
                             replyData.replies.forEach(reply => {
                                 repliesContainer.innerHTML += `
                               <div class="border p-2 mb-2">
                                 <p><strong>${reply.userName}</strong> - ${new Date(reply.dateStamp).toLocaleString()}</p>
                                 <p>${reply.content}</p>
                                 <button class="btn btn-danger btn-sm" onclick="deleteReply(${reply.id}, ${reply.commentId})">Delete Reply</button>
                                 <button class="btn btn-warning btn-sm" onclick="editReply(${reply.id}, '${reply.content}', ${reply.commentId})">Edit Reply</button>
                               </div>
                             `;
                             });
                         }
                     }
                 });
             });
     }

     // Add Comment
     function addComment(articleId) {
         let content = document.getElementById(`commentContent-${articleId}`).value;

         fetch(`/User/AddComment`, {
             method: "POST",
             headers: { "Content-Type": "application/json" },
             body: JSON.stringify({ ArticleId: articleId, UserId: userId, Content: content })
         }).then(() => {
             document.getElementById(`commentContent-${articleId}`).value = "";
             fetchComments(articleId);
         });
     }

     // Delete Comment
     function deleteComment(commentId, articleId) {
         fetch(`/User/DeleteComment`, {
             method: "POST",
             headers: { "Content-Type": "application/json" },
             body: JSON.stringify({ CommentId: commentId, UserId: userId })
         }).then(() => fetchComments(articleId));
     }

     // Edit Comment
     function editComment(commentId, oldContent, articleId) {
         let newContent = prompt("Edit your comment:", oldContent);
         if (newContent !== null) {
             fetch(`/User/EditComment`, {
                 method: "POST",
                 headers: { "Content-Type": "application/json" },
                 body: JSON.stringify({ CommentId: commentId, UserId: userId, Content: newContent })
             }).then(() => fetchComments(articleId));
         }
     }


     // Toggle Comment Like (for liking a comment)
     function toggleCommentLike(commentId) {
         fetch(`/User/ToggleCommentLike`, {
             method: "POST",
             headers: { "Content-Type": "application/json" },
             body: JSON.stringify({ CommentId: commentId, UserId: userId })
         })
             .then(response => response.json())
             .then(data => {
                 console.log(data.message);
                 // Optionally, refresh comments if needed to update like count display for the comment
                 // fetchComments(articleId);
             })
             .catch(error => console.error("Error toggling comment like:", error));
     }




     // Toggle Replies
     function toggleReplies(commentId) {
         let section = document.getElementById("replySection-" + commentId);
         if (section.style.display === "none") {
             section.style.display = "block";
             fetchReplies(commentId);
         } else {
             section.style.display = "none";
         }
     }





     function fetchReplies(commentId) {
         fetch(`/User/GetReplies?commentId=${commentId}`)
             .then(response => response.json())
             .then(replies => {
                 let repliesContainer = document.getElementById(`repliesContainer-${commentId}`);
                 let replyCountElement = document.getElementById(`replyCount-${commentId}`);
                 repliesContainer.innerHTML = ""; // Clear old replies

                 if (replies.length === 0) {
                     repliesContainer.innerHTML = "<p>No replies yet.</p>";
                 } else {
                     replyCountElement.innerText = replies.length;
                     replies.forEach(reply => {
                         // Check if userName exists; if not, use a default value
                         const userName = reply.userName ? reply.userName : 'Anonymous';
                         const dateStamp = new Date(reply.dateStamp).toLocaleString();
                         const content = reply.content ? reply.content : '[No content]';

                         repliesContainer.innerHTML += `
                                  <div id="reply-${reply.id}" class="border p-2 mb-2">
                                      <p><strong>${userName}</strong> - ${dateStamp}</p>
                                      <p>${content}</p>
                                      <button class="btn btn-warning btn-sm" onclick="editReply(${reply.id}, '${content}')">Edit</button>
                                      <button class="btn btn-danger btn-sm" onclick="deleteReply(${reply.id})">Delete</button>
                                      <button class="btn btn-info btn-sm" onclick="likeReply(${reply.id})">Like</button>
                                      <span id="likeCount-${reply.id}">${reply.likes || 0}</span>
                                  </div>
                              `;
                     });
                 }
             });
     }


     // Add Reply
     function addReply(commentId) {
         let content = document.getElementById(`replyContent-${commentId}`).value;

         fetch(`/User/AddReply`, {
             method: "POST",
             headers: { "Content-Type": "application/json" },
             body: JSON.stringify({ CommentId: commentId, UserId: userId, Content: content })
         }).then(() => {
             document.getElementById(`replyContent-${commentId}`).value = "";
             fetchReplies(commentId);
         });
     }


     // Delete a specific reply
     function deleteReply(replyId, commentId) {
         fetch(`/User/DeleteReply`, {
             method: "POST",
             headers: { "Content-Type": "application/json" },
             body: JSON.stringify({ ReplyId: replyId, UserId: userId })
         }).then(() => fetchReplies(commentId));
     }

     // Edit a specific reply
     function editReply(replyId, oldContent, commentId) {
         let newContent = prompt("Edit your reply:", oldContent);
         if (newContent !== null) {
             fetch(`/User/EditReply`, {
                 method: "POST",
                 headers: { "Content-Type": "application/json" },
                 body: JSON.stringify({ ReplyId: replyId, UserId: userId, Content: newContent })
             }).then(() => fetchReplies(commentId));
         }
     }

     // Toggle Like/Unlike for a specific reply
     function toggleReplyLike(replyId) {
         fetch(`/User/ToggleReplyLike`, {
             method: "POST",
             headers: { "Content-Type": "application/json" },
             body: JSON.stringify({ ReplyId: replyId, UserId: userId })
         }).then(response => response.json())
             .then(data => {
                 console.log(data.message);
                 // Optionally refresh the replies if needed to update the like count
                 // fetchReplies(commentId);
             })
             .catch(error => console.error("Error toggling reply like:", error));
     }

     // Fetch Like count for a specific reply
     function GetReplyLikeCounts(replyId) {
         fetch(`/User/GetReplyLikeCount?replyId=${replyId}`)
             .then(response => response.json())
             .then(data => {
                 document.getElementById(`replyLikeCount-${replyId}`).innerText = data.likeCount;
             });
     }

</script>